---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => Number(b.data.featured) - Number(a.data.featured),
);
---

<BaseLayout title="Projects | Allie" description="Projects and experiments I am building.">
  <div class="stack">
    {
      projects.map((project) => (
        <article class="card">
          <h2>{project.data.name}</h2>
          <p>{project.data.summary}</p>
          <p class="muted">Tech: {project.data.tech.join(", ")}</p>
          <p>
            {project.data.repo && <a href={project.data.repo}>Repository</a>}
            {project.data.repo && project.data.live && " · "}
            {project.data.live && <a href={project.data.live}>Live site</a>}
          </p>
        </article>
      ))
    }
  </div>
</BaseLayout>
