---
import BaseLayout from "../layouts/BaseLayout.astro";
import booksData from "../data/books.json";
import { parseBooksData } from "../utils/books";

const { currentlyReading, wishlist, completed } = parseBooksData(booksData);
---

<BaseLayout title="Books | Allie" description="Book wishlist and reading progress.">
  <section class="stack">
    <h2>Currently Reading</h2>
    {
      currentlyReading.length ? (
        currentlyReading.map((book) => (
          <article class="card">
            <h3>{book.title}</h3>
            <p class="muted">by {book.author}</p>
            <p>Progress: {book.progress}%</p>
            {book.notes && <p>{book.notes}</p>}
          </article>
        ))
      ) : (
        <p class="muted">No active reads right now.</p>
      )
    }
  </section>

  <section class="stack">
    <h2>Wishlist</h2>
    {
      wishlist.length ? (
        wishlist.map((book) => (
          <article class="card">
            <h3>{book.title}</h3>
            <p class="muted">by {book.author}</p>
            {book.priority && <p>Priority: {book.priority}</p>}
            {book.notes && <p>{book.notes}</p>}
          </article>
        ))
      ) : (
        <p class="muted">Wishlist is empty.</p>
      )
    }
  </section>

  <section class="stack">
    <h2>Completed</h2>
    {
      completed.length ? (
        completed.map((book) => (
          <article class="card">
            <h3>{book.title}</h3>
            <p class="muted">by {book.author}</p>
            {book.notes && <p>{book.notes}</p>}
          </article>
        ))
      ) : (
        <p class="muted">No completed books yet.</p>
      )
    }
  </section>
</BaseLayout>
